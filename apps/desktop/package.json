{
  "name": "@apply/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build":    "tsc",
    "dev":      "wait-on tcp:3000 && pnpm build && electron dist/main/index.js",
    "start":    "electron dist/main/index.js",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "pack":     "electron-builder --dir",
    "dist":     "electron-builder",
    "clean":    "rm -rf dist release"
  },
  "dependencies": {
    "@apply/db": "workspace:*",
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^20.12.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
